<?xml version="1.0"?>
<Actions>
    <Action id="sendPushNotification">
        <Name>Send Push Notification</Name>
        <CallbackMethod>sendPushNotification</CallbackMethod>
        <ConfigUI>
            <Field type="textfield" id="title" defaultValue="Domio">
                <Label>Title:</Label>
            </Field>
            <Field type="label" id="titleHelp" alignWithControl="true"
                   fontSize="small" fontColor="darkgray">
                <Label>Optional. Use %%v:varName%% for variables, %%d:deviceId:stateName%% for device states.</Label>
            </Field>

            <Field type="textfield" id="body">
                <Label>Body:</Label>
            </Field>
            <Field type="label" id="bodyHelp" alignWithControl="true"
                   fontSize="small" fontColor="darkgray">
                <Label>Required. Supports same substitution as title.</Label>
            </Field>

            <Field type="separator" id="sep1"/>

            <Field type="menu" id="deepLinkType" defaultValue="none">
                <Label>Deep Link:</Label>
                <List>
                    <Option value="none">None</Option>
                    <Option value="device">Device</Option>
                    <Option value="page">Control Page</Option>
                    <Option value="action">Action Group</Option>
                    <Option value="log">Event Log</Option>
                </List>
            </Field>
            <Field type="menu" id="deepLinkDeviceId" defaultValue=""
                   visibleBindingId="deepLinkType" visibleBindingValue="device">
                <Label>Device:</Label>
                <List class="self" method="deviceListGenerator" dynamicReload="true" />
            </Field>
            <Field type="menu" id="deepLinkPageId" defaultValue=""
                   visibleBindingId="deepLinkType" visibleBindingValue="page">
                <Label>Control Page:</Label>
                <List class="self" method="controlPageListGenerator" dynamicReload="true" />
            </Field>
            <Field type="menu" id="deepLinkActionId" defaultValue=""
                   visibleBindingId="deepLinkType" visibleBindingValue="action">
                <Label>Action Group:</Label>
                <List class="self" method="actionGroupListGenerator" dynamicReload="true" />
            </Field>

            <Field type="separator" id="sep2"/>

            <Field type="checkbox" id="playSound" defaultValue="true">
                <Label>Play sound:</Label>
                <Description>Play notification sound on device</Description>
            </Field>
        </ConfigUI>
    </Action>
    <!-- IWS HTTP endpoints (hidden from UI) -->
    <Action id="status" uiPath="hidden">
        <Name>History API Status</Name>
        <CallbackMethod>handle_status</CallbackMethod>
    </Action>
    <Action id="history" uiPath="hidden">
        <Name>Device History</Name>
        <CallbackMethod>handle_history</CallbackMethod>
    </Action>
    <Action id="refreshWidgets">
        <Name>Refresh Domio Widgets</Name>
        <CallbackMethod>refreshWidgets</CallbackMethod>
        <ConfigUI>
            <Field type="label" id="widgetHelp"
                   fontSize="small" fontColor="darkgray">
                <Label>Sends a silent push to all registered devices, triggering an immediate widget refresh. Use this in triggers after device state changes that should be reflected on home screen widgets.</Label>
            </Field>
        </ConfigUI>
    </Action>
</Actions>
